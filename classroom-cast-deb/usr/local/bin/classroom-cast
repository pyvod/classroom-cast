#!/bin/bash
# 班级投屏 Launcher
# 激活虚拟环境并启动主程序

INSTALL_DIR=/opt/classroom-cast
VENV_DIR=$INSTALL_DIR/venv
WHEEL_DIR=$INSTALL_DIR/python-wheels

# Ensure virtualenv exists (lazy setup if postinst didn't run)
if [ ! -d "$VENV_DIR" ]; then
    echo "正在初始化环境，请稍候..."
    python3 -m venv "$VENV_DIR"

    PYTHON_VER=$("$VENV_DIR/bin/python" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
    BASE_PKGS="pyqt5_qt5 PyQt5 pyqt5_sip aiohttp aiosignal attrs frozenlist multidict yarl pillow qrcode cffi pycparser cryptography zeroconf ifaddr"

    # Upgrade pip first (UOS V20 pip 18.1 doesn't support manylinux2014)
    "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEEL_DIR" --upgrade pip 2>/dev/null || true

    if [ "$PYTHON_VER" = "3.7" ]; then
        "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEEL_DIR" $BASE_PKGS 2>/dev/null || \
        "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEEL_DIR" $BASE_PKGS
    else
        "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEEL_DIR" $BASE_PKGS aiohappyeyeballs propcache 2>/dev/null || \
        "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEEL_DIR" $BASE_PKGS aiohappyeyeballs propcache
    fi
fi

export PATH="$VENV_DIR/bin:$PATH"
exec "$VENV_DIR/bin/python3" "$INSTALL_DIR/main.py"
